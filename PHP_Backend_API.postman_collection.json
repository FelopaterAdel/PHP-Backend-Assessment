{
  "info": {
    "_postman_id": "phptask-collection",
    "name": "PHP Backend API - Products",
    "description": "RESTful API collection for managing products with inventory management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products?page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number for pagination"
                },
                {
                  "key": "per_page",
                  "value": "10",
                  "description": "Number of products per page"
                }
              ]
            },
            "description": "Retrieve all products with pagination support. Results are cached for 1 hour."
          },
          "response": []
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"PROD-001\",\n  \"name\": \"Sample Product\",\n  \"description\": \"This is a sample product\",\n  \"price\": 29.99,\n  \"stock_quantity\": 100,\n  \"low_stock_threshold\": 10,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Create a new product. Returns 201 Created with the new product data."
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "description": "Retrieve a specific product by its ID."
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product Name\",\n  \"price\": 39.99,\n  \"stock_quantity\": 150\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "description": "Update a product (supports partial updates). Provide only the fields you want to update."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "description": "Delete a product using soft delete. Data is preserved in the database for audit purposes."
          },
          "response": []
        },
        {
          "name": "Get Low Stock Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/low-stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "low-stock"
              ]
            },
            "description": "Retrieve all products where stock quantity is at or below the low stock threshold."
          },
          "response": []
        },
        {
          "name": "Adjust Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/1/stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1",
                "stock"
              ]
            },
            "description": "Adjust stock quantity for a product. Positive numbers increase stock, negative numbers decrease it. Cannot be zero."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost",
      "type": "string",
      "description": "Base URL for the API (e.g., http://localhost or http://app)"
    }
  ]
}
